generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  VISITOR
  ARTIST
  ADMIN
  FOUNDER

  @@map("user_role")
}

enum ElementType {
  studios
  presence
  foundation
  press
  law

  @@map("element_type")
}

enum ApplicationStage {
  WRITING
  RECORDING
  RELEASED
  TOURING

  @@map("application_stage")
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  INVITED
  DECLINED
  PARTNER

  @@map("application_status")
}

enum ProjectType {
  SINGLE
  EP
  ALBUM
  FILM_SCORE
  COMPILATION

  @@map("project_type")
}

enum ProjectStatus {
  DEVELOPMENT
  RECORDING
  MIXING
  MASTERING
  RELEASING
  RELEASED

  @@map("project_status")
}

enum RevenueSource {
  SYNC
  DISTRIBUTION
  VINYL
  SERVICE_FEE
  STIPEND

  @@map("revenue_source")
}

model User {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String        @unique
  passwordHash String        @map("password_hash")
  firstName    String?       @map("first_name")
  lastName     String?       @map("last_name")
  role         UserRole      @default(VISITOR)
  elements     ElementType[] @default([])
  createdAt    DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime?     @default(now()) @map("updated_at") @db.Timestamptz(6)
  applications Application[]
  projects     Project[]

  @@map("users")
}

model Application {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String?           @map("user_id") @db.Uuid
  artistName     String            @map("artist_name")
  email          String
  phone          String?
  genre          String?
  stage          ApplicationStage?
  portfolioUrls  String[]          @map("portfolio_urls")
  servicesNeeded String[]          @map("services_needed")
  whatTheyBuild  String?           @map("what_they_build")
  whyStudios     String?           @map("why_studios")
  retainsIp      String?           @map("retains_ip")
  consent        Boolean?          @default(false)
  status         ApplicationStatus? @default(PENDING)
  calendlyUrl    String?           @map("calendly_url")
  reviewedAt     DateTime?         @map("reviewed_at") @db.Timestamptz(6)
  createdAt      DateTime?         @default(now()) @map("created_at") @db.Timestamptz(6)
  element        ElementType       @default(studios)
  user           User?             @relation(fields: [userId], references: [id])

  @@index([element])
  @@index([status])
  @@map("applications")
}

model Project {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  artistId     String?       @map("artist_id") @db.Uuid
  element      ElementType   @default(studios)
  title        String
  type         ProjectType?
  status       ProjectStatus? @default(DEVELOPMENT)
  releaseDate  DateTime?     @map("release_date") @db.Date
  assetUrl     String?       @map("asset_url")
  syncEligible Boolean?      @default(true) @map("sync_eligible")
  revenueTotal Decimal?      @default(0) @map("revenue_total") @db.Decimal(10, 2)
  createdAt    DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime?     @default(now()) @map("updated_at") @db.Timestamptz(6)
  artist       User?         @relation(fields: [artistId], references: [id])
  revenue      RevenueEntry[]

  @@index([element])
  @@index([artistId])
  @@map("projects")
}

model RevenueEntry {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId     String?        @map("project_id") @db.Uuid
  element       ElementType    @default(studios)
  amount        Decimal        @db.Decimal(10, 2)
  source        RevenueSource?
  artistShare   Decimal?       @map("artist_share") @db.Decimal(10, 2)
  guildShare    Decimal?       @map("guild_share") @db.Decimal(10, 2)
  stipendShare  Decimal?       @map("stipend_share") @db.Decimal(10, 2)
  infraShare    Decimal?       @map("infra_share") @db.Decimal(10, 2)
  founderShare  Decimal?       @map("founder_share") @db.Decimal(10, 2)
  createdAt     DateTime?      @default(now()) @map("created_at") @db.Timestamptz(6)
  project       Project?       @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@map("revenue_entries")
}

// Shared commerce records for the Whole Body Earth Store. These are intentionally
// pillar-aware rather than scoped to any one product surface.
model Product {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug             String?   @unique
  title            String
  type             String
  pillar           String
  description      String?
  priceCents       Int?      @map("price_cents")
  imageUrl         String?   @map("image_url")
  stripeProductId  String?   @unique @map("stripe_product_id")
  stripePriceId    String?   @unique @map("stripe_price_id")
  fulfillmentType  String    @default("manual_delivery") @map("fulfillment_type")
  metadata         Json      @db.JsonB
  status           String    @default("draft")
  featured         Boolean   @default(false)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([pillar, featured, status, createdAt])
  @@map("products")
}

model Book {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title             String
  slug              String    @unique
  volumeNumber      Int?      @map("volume_number")
  author            String?
  description       String?
  digitalPriceCents Int?      @map("digital_price_cents")
  physicalPriceCents Int?     @map("physical_price_cents")
  imageUrl          String?   @map("image_url")
  status            String    @default("forthcoming")
  featured          Boolean   @default(false)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([featured, status, createdAt])
  @@map("books")
}

model Purchase {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                  String?   @map("user_id") @db.Uuid
  productType             String    @map("product_type")
  productId               String?   @map("product_id") @db.Uuid
  stripeCheckoutSessionId String?   @unique @map("stripe_checkout_session_id")
  stripePaymentIntentId   String?   @unique @map("stripe_payment_intent_id")
  customerEmail           String?   @map("customer_email")
  fulfillmentStatus       String    @default("awaiting_payment") @map("fulfillment_status")
  passportId              String?   @map("passport_id")
  metadata                Json      @db.JsonB
  status                  String    @default("pending")
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([productId])
  @@index([userId])
  @@map("purchases")
}

// Canonical gatherings system. `event_date` is intentionally retained as the
// start timestamp because existing homepage and live-shelf queries already use
// it; all calendar surfaces read this same record.
model Event {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title            String
  slug             String    @unique
  type             String
  pillar           String
  description      String?
  eventDate        DateTime  @map("event_date") @db.Timestamptz(6)
  endDate          DateTime? @map("end_date") @db.Timestamptz(6)
  recurring        String?
  recurringUntil   DateTime? @map("recurring_until") @db.Timestamptz(6)
  location         String?
  locationType     String?   @map("location_type")
  locationAddress  String?   @map("location_address")
  virtualUrl       String?   @map("virtual_url")
  capacity         Int?
  priceCents       Int?      @map("price_cents")
  stripeProductId  String?   @unique @map("stripe_product_id")
  stripePriceId    String?   @unique @map("stripe_price_id")
  status           String    @default("draft")
  publishedAt      DateTime? @map("published_at") @db.Timestamptz(6)
  requiresApproval Boolean   @default(false) @map("requires_approval")
  membersOnly      Boolean   @default(false) @map("members_only")
  waitlistEnabled  Boolean   @default(false) @map("waitlist_enabled")
  imageUrl         String?   @map("image_url")
  createdBy        String?   @map("created_by") @db.Uuid
  parentEventId    String?   @map("parent_event_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  rsvps            Rsvp[]
  parentEvent      Event?    @relation("EventInstances", fields: [parentEventId], references: [id])
  instances        Event[]   @relation("EventInstances")

  @@index([status, eventDate])
  @@index([pillar, status])
  @@map("events")
}

model Rsvp {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId                 String   @map("event_id") @db.Uuid
  userId                  String?  @map("user_id") @db.Uuid
  name                    String?
  email                   String?
  phone                   String?
  status                  String   @default("pending")
  isMember                Boolean  @default(false) @map("is_member")
  firstTime               Boolean  @default(false) @map("first_time")
  stripeCheckoutSessionId String?  @unique @map("stripe_checkout_session_id")
  stripePaymentIntentId   String?  @map("stripe_payment_intent_id")
  amountPaidCents         Int      @default(0) @map("amount_paid_cents")
  reservationExpiresAt    DateTime? @map("reservation_expires_at") @db.Timestamptz(6)
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  event                   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, status])
  @@map("rsvps")
}

model Testimonial {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quote        String
  authorName   String    @map("author_name") @db.VarChar(100)
  houseNumber  Int?      @map("house_number")
  pillar       String
  avatarUrl    String?   @map("avatar_url")
  role         String?   @db.VarChar(100)
  joinedDate   DateTime? @map("joined_date") @db.Date
  featured     Boolean   @default(false)
  status       String    @default("active") @db.VarChar(20)
  displayOrder Int       @default(0) @map("display_order")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([status, displayOrder, createdAt])
  @@map("testimonials")
}

model PillarActivity {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String    @unique
  pillar      String
  kind        String
  title       String
  kicker      String
  summary     String
  href        String
  ctaLabel    String    @map("cta_label")
  startsAt    DateTime? @map("starts_at") @db.Timestamptz(6)
  endsAt      DateTime? @map("ends_at") @db.Timestamptz(6)
  priority    Int       @default(0)
  status      String    @default("draft")
  publishedAt DateTime? @map("published_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([pillar, status, priority, startsAt])
  @@map("pillar_activities")
}

model JobPosting {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title            String           @db.VarChar(200)
  slug             String           @unique @db.VarChar(200)
  department       String?          @db.VarChar(100)
  pillar           String?          @db.VarChar(50)
  type             String?          @db.VarChar(50)
  location         String?          @db.VarChar(100)
  remote           Boolean          @default(true)
  compensation     String?          @db.VarChar(100)
  description      String
  responsibilities String[]         @default([])
  requirements     String[]         @default([])
  niceToHave       String[]         @default([]) @map("nice_to_have")
  benefits         String[]         @default([])
  status           String           @default("draft") @db.VarChar(20)
  postedDate       DateTime?        @map("posted_date") @db.Timestamptz(6)
  closingDate      DateTime?        @map("closing_date") @db.Timestamptz(6)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @default(now()) @map("updated_at") @db.Timestamptz(6)
  applications     JobApplication[]

  @@index([status])
  @@map("job_postings")
}

model JobApplication {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobId          String      @map("job_id") @db.Uuid
  userId         String?     @map("user_id") @db.Uuid
  fullName       String      @map("full_name") @db.VarChar(200)
  email          String      @db.VarChar(200)
  phone          String?     @db.VarChar(50)
  location       String?     @db.VarChar(200)
  linkedinUrl    String?     @map("linkedin_url")
  portfolioUrl   String?     @map("portfolio_url")
  websiteUrl     String?     @map("website_url")
  coverLetter    String?     @map("cover_letter")
  resumeUrl      String?     @map("resume_url")
  additionalFiles String[]   @default([]) @map("additional_files")
  hasReading     Boolean     @default(false) @map("has_reading")
  houseNumber    Int?        @map("house_number")
  element        String?     @db.VarChar(50)
  pillar         String?     @db.VarChar(50)
  status         String      @default("submitted") @db.VarChar(20)
  adminNotes     String?     @map("admin_notes")
  interviewStage String?     @map("interview_stage") @db.VarChar(50)
  referredBy     String?     @map("referred_by") @db.VarChar(200)
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)
  job            JobPosting  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([status])
  @@index([email])
  @@map("job_applications")
}

model Reading {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String?  @map("user_id") @db.Uuid
  birthDate       DateTime @map("birth_date") @db.Date
  birthTime       String?  @map("birth_time") @db.VarChar(5)
  birthPlace      String   @map("birth_place") @db.VarChar(200)
  hasBirthTime    Boolean  @default(false) @map("has_birth_time")
  dominantPillar  String   @map("dominant_pillar") @db.VarChar(50)
  dominantBody    String   @map("dominant_body") @db.VarChar(50)
  secondaryPillar String?  @map("secondary_pillar") @db.VarChar(50)
  isGuardian      Boolean  @default(false) @map("is_guardian")
  confidence      Int
  chartJson       Json     @map("chart_json")
  readingJson     Json     @map("reading_json")
  engineVersion   String   @default("quincunx-v1") @map("engine_version") @db.VarChar(50)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId, createdAt])
  @@index([dominantPillar, createdAt])
  @@map("readings")
}
